# OpenClaw runtime locations on the VPS.
OPENCLAW_USER_HOME=/home/clawd
OPENCLAW_HOME=/home/clawd/.openclaw
OPENCLAW_BIN_DIR=/home/clawd/.npm-global/bin
MISSION_CONTROL_WORKSPACE_ROOT=/home/clawd/clawd

# Unrestricted browser terminal. Enabled by default; set false to disable.
MISSION_CONTROL_TERMINAL_ENABLED=true
MISSION_CONTROL_TERMINAL_CWD=/home/clawd/clawd
MISSION_CONTROL_TERMINAL_TIMEOUT_MS=60000
MISSION_CONTROL_TERMINAL_MAX_BUFFER=4194304

# Bridge runner for Codex CLI or shell jobs. Logs are written under .agent/ in this directory.
MISSION_CONTROL_BRIDGE_CWD=/home/clawd/clawd/openclaw-mission-control
MISSION_CONTROL_CODEX_MODEL=gpt-5.2
MISSION_CONTROL_BRIDGE_TIMEOUT_MS=600000
MISSION_CONTROL_BRIDGE_MAX_BUFFER=16777216

# Optional overrides if the runtime uses non-standard paths.
# OPENCLAW_TASKS_DB=/home/clawd/.openclaw/tasks/runs.sqlite
# OPENCLAW_MEMORY_DB=/home/clawd/.openclaw/memory/main.sqlite
# OPENCLAW_SESSIONS_FILE=/home/clawd/.openclaw/agents/main/sessions/sessions.json
# OPENCLAW_CONFIG_FILE=/home/clawd/.openclaw/openclaw.json
# OPENCLAW_CRON_FILE=/home/clawd/.openclaw/cron/jobs.json
